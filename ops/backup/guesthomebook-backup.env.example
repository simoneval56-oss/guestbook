#
# Copy to /etc/guesthomebook-backup.env on VPS.
# chmod 600 /etc/guesthomebook-backup.env
#

# Mode A (recommended): direct Postgres connection string.
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres?sslmode=require

# Mode B (no DB password): leave DATABASE_URL empty and use Supabase CLI token mode.
# Requires `supabase` CLI installed on VPS and metadata files in /opt/guestbook/supabase/.temp/.
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_WORKDIR=/opt/guestbook
# Optional bootstrap if metadata files are missing:
# SUPABASE_PROJECT_REF=<project-ref>
# SUPABASE_POOLER_URL=postgresql://postgres.<project-ref>@aws-1-<region>.pooler.supabase.com:5432/postgres

# Storage and retention
BACKUP_DIR=/var/backups/guesthomebook
RETENTION_DAYS=14
BACKUP_SCHEMAS=public

# Restore verification container
RESTORE_PG_IMAGE=public.ecr.aws/supabase/postgres:17.6.1.054
RESTORE_PG_PORT=55432
RESTORE_PG_PASSWORD=guesthomebook_restore_check
RESTORE_PG_USER=supabase_admin

# Optional alerting
ALERT_WEBHOOK_URL=
ALERT_NOTIFY_SUCCESS=false

# Optional VPS snapshot (Hetzner helper)
ENABLE_VPS_SNAPSHOT=false
SNAPSHOT_SCRIPT=/opt/guestbook/ops/backup/hetzner-snapshot.sh
HCLOUD_TOKEN=
HCLOUD_SERVER_ID=
HCLOUD_SNAPSHOT_DESCRIPTION=
